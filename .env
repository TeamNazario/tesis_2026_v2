# ─────────────────────────────────────────────────────────────────────────────
# BIOFLUID D32 - Variables de entorno para despliegue Docker local
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=biofluid_db
DB_USER=root
DB_PASSWORD=biofluid123

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
APP_TOKEN_SECRET=change-this-secret-in-production-at-least-32-bytes
APP_TOKEN_EXPIRATION_MINUTES=120

# ── API Externa - ApisPeru (consulta RUC/DNI) ─────────────────────────────────
APISPERU_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJlbWFpbCI6ImJyeWFuYmd6dUBnbWFpbC5jb20ifQ.9RN9DoX8b91NVbWMAjljxyrOYoDASdG38XeQJbOA_uw

# ── API Key para integraciones externas (n8n, webhooks) ──────────────────────
APP_API_KEY=biofluid-n8n-api-key-2026

# ── CORS: origenes permitidos (agrega tu URL ngrok cuando lo uses) ────────────
# Ejemplo con ngrok: http://localhost:4200,https://xxxx.ngrok-free.app
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:5173,https://*.ngrok-free.app,https://*.ngrok.io

# ── Configuración de la aplicación ───────────────────────────────────────────
APP_COTIZACIONES_VENCIMIENTO_CRON=0 0 * * * *
