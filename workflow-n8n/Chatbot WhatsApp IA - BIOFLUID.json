{
  "name": "Chatbot WhatsApp - Productos con IA",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const mensaje = $input.item.json.messages[0].text.body.toLowerCase();\nconst keywordsCotizacion = [\n  'cotiz','cotizacion','cotización',\n  'quiero comprar','quiero pedir','deseo comprar',\n  'necesito comprar','precio de',\n  'cuánto cuesta','cuanto cuesta','cuánto vale','cuanto vale',\n  'hacer pedido','realizar pedido','pedir',\n  'comprar','adquirir','solicitar',\n  'presupuesto','orden de compra'\n];\nconst esConsulta = !keywordsCotizacion.some(k => mensaje.includes(k));\nreturn {\n  json: {\n    ...($input.item.json),\n    intencion: esConsulta ? 'CONSULTA' : 'COTIZACION',\n    mensaje_original: $input.item.json.messages[0].text.body\n  }\n};"
      },
      "id": "7b96fbdb-4dc2-43b5-97c5-789287d95095",
      "name": "Detectar Intencion",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -800,
        -256
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 1
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intencion }}",
                    "rightValue": "CONSULTA",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "CONSULTA"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 1
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intencion }}",
                    "rightValue": "COTIZACION",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "COTIZACION"
            }
          ]
        },
        "options": {}
      },
      "id": "e92bfbe6-e2ea-4d90-99ad-5ab66ed68f68",
