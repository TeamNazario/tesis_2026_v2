# ─────────────────────────────────────────────────────────────────────────────
# BIOFLUID D32 - Variables de entorno para despliegue Docker local
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Edita los valores según tu entorno
#   3. Nunca subas el archivo .env al repositorio (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=biofluid_db
DB_USER=root
DB_PASSWORD=biofluid123

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Mínimo 32 caracteres para HS256. Cambia esto en producción.
APP_TOKEN_SECRET=change-this-secret-in-production-at-least-32-bytes
APP_TOKEN_EXPIRATION_MINUTES=120

# ── API Externa - ApisPeru (consulta RUC/DNI) ─────────────────────────────────
# Obtén tu token en: https://dniruc.apisperu.com
# Déjalo vacío si no usas la integración de consulta RUC/DNI
APISPERU_TOKEN=

# ── API Key para integraciones externas (n8n, webhooks) ──────────────────────
# Usar este valor en el header X-API-Key de n8n
APP_API_KEY=biofluid-n8n-api-key-2026

# ── Configuración de la aplicación ───────────────────────────────────────────
# Cron para marcar cotizaciones vencidas (por defecto: cada hora)
APP_COTIZACIONES_VENCIMIENTO_CRON=0 0 * * * *
